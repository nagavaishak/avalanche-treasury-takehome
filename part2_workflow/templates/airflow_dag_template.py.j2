"""
{{ spec.metadata.name }} — generated by promoteit on {{ generated_at }}
{{ "=" * (spec.metadata.name | length + 40) }}

Source: {{ spec.metadata.source_path }}
Owner:  {{ spec.metadata.owner }}
Oncall: {{ spec.metadata.oncall }}
SLA:    {{ spec.freshness.sla }}
Template version: {{ template_version }}

Purpose:
{{ spec.purpose | indent(4) }}

Reuses utilities: {{ spec.dependencies.utilities | join(", ") }}

NOTE: This file is regenerated when the spec changes. Manual edits will be
overwritten unless they live behind the `# region custom` markers below.
"""
from __future__ import annotations

from datetime import datetime, timedelta

from airflow import DAG
from airflow.operators.python import PythonOperator

# --- Reused utilities (LLM-suggested; verified by author in promoteit PR) ---
{% for util in spec.dependencies.utilities %}
from utilities.{{ util }} import {{ util | replace("_", " ") | title | replace(" ", "") }}
{% endfor %}

# --- Author-written transforms imported from the promoted module ---
from pipelines.{{ spec.metadata.name }} import (
    {% for fn in transforms_to_import %}{{ fn }},
    {% endfor %}
)

DEFAULT_ARGS = {
    "owner": "{{ spec.metadata.owner }}",
    "depends_on_past": False,
    "email_on_failure": False,            # paged via oncall service, not email
    "retries": {{ spec.retries.max }},
    "retry_exponential_backoff": True,
    "retry_delay": timedelta(seconds={{ spec.retries.backoff_seconds[0] }}),
    "max_retry_delay": timedelta(seconds={{ spec.retries.backoff_seconds[-1] }}),
    "sla": timedelta(hours={{ spec.freshness.sla | replace("h", "") | int }}),
}

with DAG(
    dag_id="{{ spec.metadata.name }}",
    description="{{ spec.purpose | replace('\n', ' ') | truncate(140) }}",
    schedule_interval="{{ spec.schedule_cron }}",
    start_date=datetime(2026, 1, 1),
    catchup=False,
    default_args=DEFAULT_ARGS,
    tags=["{{ spec.metadata.team }}", "{{ spec.freshness.classification }}", "promoteit-generated"],
) as dag:

    {% for task in tasks %}
    {{ task.id }} = PythonOperator(
        task_id="{{ task.id }}",
        python_callable={{ task.callable }},
        op_kwargs={{ task.op_kwargs | tojson }},
    )
    {% endfor %}

    # Wire dependencies in spec-declared order.
    {{ tasks | map(attribute="id") | join(" >> ") }}

    # region custom
    # ----------------------------------------------------------------------
    # Add author-owned customizations below this line. promoteit will not
    # overwrite anything between these region markers.
    #
    # ----------------------------------------------------------------------
    # endregion custom
